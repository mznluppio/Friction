# ─────────────────────────────────────────────────────────────────────────────
# Friction — Environment variables reference
# Copy this file to .env and fill in only what you need.
# The app configures most settings through its built-in onboarding/settings UI.
# ─────────────────────────────────────────────────────────────────────────────

# ── CLI command overrides (optional) ─────────────────────────────────────────
# Override the binary path for each supported CLI.
# Defaults to the CLI alias name (e.g. "claude" → looks up PATH).
FRICTION_CLAUDE_CLI=claude
FRICTION_CODEX_CLI=codex
FRICTION_GEMINI_CLI=gemini
# FRICTION_OPENCODE_CLI=opencode   # uncomment to override

# ── Global CLI timeout ────────────────────────────────────────────────────────
FRICTION_PHASE3_CLI_TIMEOUT_SECS=240

# ── Trust Judge provider ──────────────────────────────────────────────────────
# Used for Phase 3 confidence scoring.
# Options: haiku | flash | ollama | opencode
FRICTION_JUDGE_PROVIDER=haiku
FRICTION_JUDGE_MODEL=

# API keys (only required for the judge provider you select)
ANTHROPIC_API_KEY=       # required for judge provider = haiku
GEMINI_API_KEY=          # required for judge provider = flash
GOOGLE_API_KEY=          # alternative to GEMINI_API_KEY

# ── Ollama (optional — for local judge) ──────────────────────────────────────
OLLAMA_HOST=http://localhost:11434

# ── Phase 3 agent overrides (optional) ───────────────────────────────────────
# Defaults to the Agent A / Agent B selected in settings.
# FRICTION_PHASE3_AGENT_A_CLI=claude
# FRICTION_PHASE3_AGENT_B_CLI=codex
