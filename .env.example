# CLI-first agent execution (phases 1/2/3)
FRICTION_CLAUDE_CLI=claude
FRICTION_CODEX_CLI=codex
FRICTION_GEMINI_CLI=gemini

# Optional default Agent B selection when not provided by caller
FRICTION_PHASE3_AGENT_B_CLI=codex

# Global CLI timeout (seconds)
FRICTION_PHASE3_CLI_TIMEOUT_SECS=240

# Judge provider for confidence scoring (haiku | flash | ollama)
FRICTION_JUDGE_PROVIDER=haiku
FRICTION_JUDGE_MODEL=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=

# Ollama endpoint (judge provider=ollama and legacy provider mode)
OLLAMA_HOST=http://localhost:11434
FRICTION_OLLAMA_HOST=http://localhost:11434

# Legacy provider mode for phase1/2 (disabled by default)
# Set to 1 only if you need the old API/provider flow.
FRICTION_ENABLE_LEGACY_PROVIDER_MODE=0
FRICTION_ARCHITECT_PROVIDER=mock
FRICTION_PRAGMATIST_PROVIDER=mock
FRICTION_ARCHITECT_MODEL=claude-sonnet-4-20250514
FRICTION_PRAGMATIST_MODEL=gpt-4o
OPENAI_API_KEY=

# Backward compatibility command path fallbacks (optional)
FRICTION_PHASE3_AGENT_A_CLI=claude
FRICTION_PHASE3_CODEX_CLI=codex
FRICTION_PHASE3_GEMINI_CLI=gemini
